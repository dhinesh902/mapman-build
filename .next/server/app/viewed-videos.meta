{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/viewed-videos/layout,_N_T_/viewed-videos/page,_N_T_/viewed-videos"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
